{
  "model_name": "qwen3:14b",
  "router_model_name": "qwen3:8b",
  "ollama_host": "http://127.0.0.1:11434",
  "workspace_root": ".",
  "access_mode": "approval",
  "max_iterations": 18,
  "max_tool_calls": 32,
  "max_repair_attempts": 3,
  "shell_timeout": 120,
  "llm_timeout": 25,
  "router_timeout": 35,
  "llm_request_retries": 2,
  "llm_retry_backoff_ms": 800,
  "router_retries": 2,
  "verbose": false,
  "allow_network": false,
  "allow_dangerous_commands": false,
  "dry_run": false,
  "diff_preview_mode": "unified",
  "max_read_chars": 14000,
  "max_search_results": 200,
  "max_files_in_context": 80,
  "state_dir_name": ".marc_a1",
  "ollama_num_ctx": 32768,
  "router_num_ctx": 2048,
  "ollama_temperature": 0.1,
  "auto_install_recommended_models": true,
  "warmup_models_on_startup": true,
  "warmup_timeout": 45
}
