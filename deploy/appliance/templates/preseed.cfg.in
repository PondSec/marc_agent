d-i debian-installer/locale string @@LOCALE@@
d-i localechooser/supported-locales multiselect @@LOCALE@@
d-i console-setup/ask_detect boolean false
d-i keyboard-configuration/xkb-keymap select @@KEYMAP@@

d-i netcfg/choose_interface select auto
d-i netcfg/get_hostname string @@HOSTNAME@@
d-i netcfg/get_domain string local
d-i netcfg/disable_autoconfig boolean false

d-i clock-setup/utc boolean true
d-i time/zone string @@TIMEZONE@@

d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

d-i apt-setup/contrib boolean true
d-i apt-setup/non-free-firmware boolean true

d-i passwd/root-login boolean false
d-i passwd/make-user boolean true
d-i passwd/user-fullname string @@FULL_NAME@@
d-i passwd/username string @@INSTALL_USERNAME@@
d-i passwd/user-default-groups string audio cdrom dip video plugdev netdev sudo

d-i partman/early_command string debconf-set partman-auto/disk "$(list-devices disk | head -n1)"
d-i partman-auto/method string regular
d-i partman-auto/choose_recipe select atomic
d-i partman-partitioning/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string curl ca-certificates git python3 python3-venv python3-pip rsync sudo zstd openssh-server
d-i pkgsel/upgrade select safe-upgrade
popularity-contest popularity-contest/participate boolean false

d-i grub-installer/only_debian boolean true
d-i grub-installer/with_other_os boolean true

d-i preseed/late_command string \
    mkdir -p /target/opt/marc-a1-installer /target/etc/marc-a1; \
    cp -a /cdrom/appliance/. /target/opt/marc-a1-installer/; \
    in-target install -D -m 0755 /opt/marc-a1-installer/marc-a1-firstboot.sh /usr/local/sbin/marc-a1-firstboot; \
    in-target install -D -m 0644 /opt/marc-a1-installer/marc-a1-firstboot.service /etc/systemd/system/marc-a1-firstboot.service; \
    in-target install -D -m 0644 /opt/marc-a1-installer/appliance.env /etc/marc-a1/appliance.env; \
    in-target chmod 0600 /etc/marc-a1/appliance.env; \
    in-target systemctl enable marc-a1-firstboot.service

d-i finish-install/reboot_in_progress note
