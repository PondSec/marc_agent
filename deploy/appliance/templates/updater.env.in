REPO_URL=@@REPO_URL@@
REPO_BRANCH=@@REPO_BRANCH@@
APP_DIR=/opt/marc-a1/app
APP_USER=@@INSTALL_USERNAME@@
APP_GROUP=@@INSTALL_USERNAME@@
BACKUP_DIR=/var/lib/marc-a1-updater/backup
CACHE_REPO_DIR=/var/lib/marc-a1-updater/repo
CURRENT_REF_FILE=/var/lib/marc-a1-updater/current-main-ref
LOCK_FILE=/var/lib/marc-a1-updater/update.lock
