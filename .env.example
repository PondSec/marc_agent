OLLAMA_HOST=http://127.0.0.1:11434
MODEL_NAME=qwen3-coder:30b
WORKSPACE_ROOT=.
ACCESS_MODE=approval
MAX_ITERATIONS=18
MAX_TOOL_CALLS=32
MAX_REPAIR_ATTEMPTS=3
SHELL_TIMEOUT=120
VERBOSE=false
ALLOW_NETWORK=false
ALLOW_DANGEROUS_COMMANDS=false
DRY_RUN=false
DIFF_PREVIEW_MODE=unified
MAX_READ_CHARS=14000
MAX_SEARCH_RESULTS=200
MAX_FILES_IN_CONTEXT=80
STATE_DIR_NAME=.marc_a1
AUTH_ENABLED=true
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_INITIAL_ADMIN_EMAIL=operator@example.com
AUTH_INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_INITIAL_ADMIN_NAME=Operator
# Optional fuer TOTP/2FA:
# AUTH_INITIAL_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP
AUTH_COOKIE_SECURE=true
AUTH_SESSION_IDLE_SECONDS=1800
AUTH_SESSION_ABSOLUTE_SECONDS=43200
AUTH_SESSION_TOUCH_INTERVAL_SECONDS=60
AUTH_MIN_PASSWORD_LENGTH=14
ALLOWED_HOSTS=127.0.0.1,localhost
# Optional fuer Reverse Proxy / feste Origin-Pruefung:
# PUBLIC_BASE_URL=https://marc.example.com
# Optional fuer bewusst freigegebene Cross-Origin-Clients:
# CORS_ALLOWED_ORIGINS=https://marc.example.com
